/* Base styles and fonts */
* {
    font-family: "JetBrainsMono Nerd Font", "JetBrains Mono", "Hack", "Noto Sans", sans-serif;
    font-size: 13px;
    font-weight: bold;
    border: none;
    border-radius: 0;
}

/* The main bar background */
window#waybar {
    background-color: rgba(20, 20, 24, 0.85);
    color: #cdd6f4;
}

/* Workspace styling */
#workspaces button {
    padding: 0 10px;
    color: #a6adc8;
    background-color: transparent;
}

#workspaces button.focused {
    color: #cba6f7;
    background-color: rgba(203, 166, 247, 0.15);
    border-radius: 6px;
}

#workspaces button.urgent {
    color: #f38ba8;
    background-color: rgba(243, 139, 168, 0.2);
    border-radius: 6px;
}

/* Individual Module Pillars */
#custom-mail, #custom-blog, #custom-clock, #battery, #network, #pulseaudio, #tray, #mode {
    padding: 0 12px;
    margin: 4px 3px;
    border-radius: 6px;
    background-color: #313244;
}

/* Color Coding for Scannability */
#custom-clock {
    color: #cba6f7;
    background-color: rgba(203, 166, 247, 0.15);
}

#pulseaudio {
    color: #f9e2af;
    background-color: rgba(249, 226, 175, 0.15);
}

#network {
    color: #89b4fa;
    background-color: rgba(137, 180, 250, 0.15);
}

#battery {
    color: #a6e3a1;
    background-color: rgba(166, 227, 161, 0.15);
}

/* Alert States */
#battery.warning {
    color: #fab387;
    background-color: rgba(250, 179, 135, 0.15);
}

#battery.critical:not(.charging) {
    color: #f38ba8;
    background-color: rgba(243, 139, 168, 0.25);
}

#network.disconnected {
    color: #f38ba8;
    background-color: rgba(243, 139, 168, 0.25);
}

/* System Tray background adjustments */
#tray {
    background-color: #242535;
}

{{ if .enable_mail -}}
/* Mail Module States */
#custom-mail.unread {
    color: #f38ba8; /* Catppuccin Red (Alert State) */
    background-color: rgba(243, 139, 168, 0.15);
    font-weight: bold;
}

#custom-mail.read-has-mail {
    color: #cdd6f4; /* Catppuccin Text (Crisp White) */
    background-color: rgba(205, 214, 244, 0.15);
}

#custom-mail.empty {
    color: #6c7086; /* Catppuccin Overlay0 (Muted Grey) */
    background-color: rgba(108, 112, 134, 0.05); /* Fainter background for empty state */
    background-color: #313244;
}
{{ end }}
{{ if .enable_blog -}}
#custom-blog {
    color: #6c7086; /* Catppuccin Overlay0 (Muted Grey) */
    background-color: rgba(108, 112, 134, 0.05);
}

/* Color Coding for Blog Freshness */
#custom-blog.fresh {
    color: #a6e3a1; /* Catppuccin Green */
    background-color: rgba(166, 227, 161, 0.15);
}

#custom-blog.stale {
    color: #fab387; /* Catppuccin Peach */
    background-color: rgba(250, 179, 135, 0.15);
}

#custom-blog.ancient {
    color: #f38ba8; /* Catppuccin Red */
    background-color: rgba(243, 139, 168, 0.15);
}
{{- end }}
